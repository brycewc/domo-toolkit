{
  "plugins": [
    "prettier-plugin-tailwindcss",
    "unified-prettier"
  ],
  "tailwindStylesheet": "./src/assets/global.css",
  "trailingComma": "none",
  "tabWidth": 2,
  "semi": true,
  "singleQuote": true,
  "quoteProps": "consistent",
  "jsxSingleQuote": true,
  "arrowParens": "always",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "endOfLine": "lf",
  "printWidth": 100
}