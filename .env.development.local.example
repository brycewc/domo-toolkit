# Copy this file to .env.development.local and fill in your values.
# .env.development.local is gitignored (*.local pattern).
#
# These variables power the standalone dev pages at:
#   http://localhost:5173/dev-lineage
#   http://localhost:5173/dev-activity-log
#
# To get a developer token, go to Domo > Admin > Authentication > Access Tokens.

VITE_DOMO_BASE_URL=https://myinstance.domo.com
VITE_DOMO_ENTITY_ID=12345
VITE_DOMO_ENTITY_TYPE=DATA_SOURCE
VITE_DOMO_OBJECT_NAME=My Dataset Name
VITE_DOMO_TOKEN=your-developer-token-here
